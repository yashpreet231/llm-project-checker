# LLM Provider: groq | ollama | huggingface | openai
LLM_PROVIDER=groq

# Groq (free) — get key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace (optional)
HF_API_KEY=

# GitHub (optional — for project submission checks)
GITHUB_TOKEN=

# Frontend URL for CORS (set to your Vercel URL after deploying)
FRONTEND_URL=https://your-app.vercel.app
